# <%= m resume.full_name %>

[<%= resume.email %>](mailto:<%= resume.email %>) -- <%= resume.phone %> -- Boston, MA -- [LinkedIn](<%= resume.links.linkedin %>) -- [GitHub](<%= resume.links.github %>)

## Summary
<%= resume.summary %>

## Skills
<% resume.skills.current.each_pair do |category, items| %>
* **<%= category -%>**: <%= items.join(', ') -%>
<% end %>

## Experience
<% resume.career.each_with_index do |job, job_i| %>
### [<%= job.company %>](<%= job.url %>) - <%= job.location %>
<%- Array(job.details).each do |detail| %>
**<%= detail.key %>**: <%= detail.value %>
<%- end %>

<% if job.summary -%>
_<%= m job.summary -%>_
<% end -%>

<% job.roles.each do |role| -%>
#### <%= role.role %>, <%= role_range(role) %>
<% if role.note -%>*<%= role.note %>*<% end %>
<% if job_i < resume.show_role_highlights -%>
<% role.highlights.each do |highlight| %>
* <%= highlight -%>
<% end %>
<% end %>

<% end -%>
<% end -%>
## Education
<% resume.education.each do |degree| %>
### [<%= degree.school %>](<%= degree.url %>) -- <%= degree.location %>

#### <%= degree.degree %>

* Graduated <%= degree.graduated %>
<% degree.highlights.each do |highlight| -%>
* <%= highlight %>
<% end -%>

<% end %>
